{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>anaconda/renovate-config"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions"
    },
    {
      "matchManagers": [
        "pre-commit"
      ],
      "groupName": "pre-commit"
    }
  ]
}
